---
title: "Taxonomic Bar Plot" 
---

```{r Load data and libraries}

library(tidyverse)
library(phyloseq)

ps = readRDS('ps_filtered.rds')


ps_phylum = tax_glom(ps,'Phylum')
```


```{r basic}
# Converting to relative abundance, then melt.
relab = ps_phylum %>% 
  microbiome::transform('compositional') %>% 
  psmelt()

# Plotting it out.
plot_basic = relab %>% ggplot(aes(Sample,Abundance,
                                  fill=Phylum)) +
  geom_col(position='stack')
plot_basic
```


```{r with formatting}

  plot_type_formatted = relab %>% 
  mutate(sample_type = str_to_title(sample_type)) %>% 
  ggplot(aes(Sample, Abundance, fill = Phylum)) +
  geom_col(position = 'stack') +
  facet_wrap(~sample_type, ncol = 4, scales = 'free') +
  
  theme_classic(base_size = 18) + 
  theme(
    axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)  # Rotate x labels
  ) +
  
  xlab(NULL)  # Remove x-axis label

plot_type_formatted

```


```{r abundance filtered}

# Finding the average abundances of each phylum
sum_of_each_phylum = taxa_sums(ps_phylum)
avg_of_each_phylum = sum_of_each_phylum/sum(sum_of_each_phylum)

# Finding which ones are <1%
below_1 = avg_of_each_phylum[avg_of_each_phylum<0.01]
to_change = names(below_1) 
to_change # Remember that each phylum is represented by the name of the first ASV in that phylum

# Changing the phylum name of these ones to '<1%'
relab_modified = relab
unique(relab_modified$Phylum)
relab_modified$Phylum[relab_modified$OTU %in% to_change] = '<1%'
unique(relab_modified$Phylum)


plot_abfilt <- relab_modified %>% 
  # Capitalize sample types
  mutate(sample_type = str_to_title(sample_type)) %>% 
  ggplot(aes(x = sample_type, y = Abundance, fill = Phylum)) +  # use sample_type here
  geom_col(position = 'stack') +
  facet_wrap(~sample_type, ncol = 4, scales = 'free') +
  theme_classic(base_size = 18) +
  theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)) +
  xlab(NULL)

plot_abfilt

```

```{r averaged plot}

# Finding the average abundance for each phylum within each body site

averaged <- relab %>%
  group_by(OTU, Phylum, sample_type) %>%
  summarize(Abundance = mean(Abundance), .groups = 'drop')

# Combine those under 1%
avg_modified <- averaged
avg_modified$Phylum[avg_modified$OTU %in% to_change] <- '<1%'


# keep only hindgut plot
plot_avg <- avg_modified %>%
  filter(sample_type == "hindgut") %>%   
  mutate(sample_type = str_to_title(sample_type)) %>%
  ggplot(aes(x = sample_type, y = Abundance, fill = Phylum)) +
  geom_col(position = 'stack') +
  theme_classic(base_size = 18) +
  theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)) +
  xlab(NULL)

plot_avg

ggsave('hindgut_plot.jpeg',
       plot = plot_avg,
       height=4, width = 6) # units are inches by default
```
