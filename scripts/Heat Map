
library(tidyverse)
library(phyloseq)
library(igraph)

# Load object
ps = readRDS('ps_filtered.rds')

# Extracting the top 10 taxa
avg_abundance = taxa_sums(ps)/sum(taxa_sums(ps)) 
# Sorting high to low
avg_abundance = sort(avg_abundance, decreasing = T)
# Taking the top 10
top_10 = avg_abundance[1:10]
# Extracting taxa names 
top_10 = names(top_10)

# Normalizing microbiome data and select only the significant taxa
# CLR transformation
ps_rel = ps %>% microbiome::transform('compositional') 
# Filter taxa
ps_filt = prune_taxa(top_10,ps_rel)


tax_genus = taxonomy %>%
  separate(col = Taxon, sep = "; " , into = c("Domain", "Phylum", "Class", "Order", "Family", "Genus", "Species"))


otu = data.frame(ps_filt@otu_table)

otu_cor = cor(t(otu))
View(otu_cor) # 10x10 grid of the correlations between taxa

rownames(otu_cor) == colnames(otu_cor)


# Replacing row and column names of otu_cor by mapping Feature.ID values
# to their corresponding Genus names using the tax_genus_names table

rownames(otu_cor) = sapply(rownames(otu_cor), function(x){
  w = which(x == tax_genus_names$Feature.ID)
  new_name = tax_genus_names$Genus[w]
  return(new_name)
})

colnames(otu_cor) = sapply(colnames(otu_cor), function(x){
  w = which(x == tax_genus_names$Feature.ID)
  new_name = tax_genus_names$Genus[w]
  return(new_name)
})

cor_cutoff = 0.3 

adj_matrix = ifelse(abs(otu_cor) > cor_cutoff, 1, 0)

diag(adj_matrix) = 0


g = graph_from_adjacency_matrix(adj_matrix, mode = "undirected", diag = FALSE)

# Calculating betweenness (unweighted)
btw = betweenness(g, normalized = TRUE)

# Result: named numeric vector
btw %>% sort

# Using absolute correlations as weights, set diag zero
wmat = abs(otu_cor)
diag(wmat) = 0
# Remove small weights
wmat[wmat < cor_cutoff] = 0

# Creating igraph with weights
g_w = graph_from_adjacency_matrix(wmat, mode = "undirected", weighted = TRUE, diag = FALSE)

# Converting to PROPER distances: distance = 1 / weight

E(g_w)$weight = 1 / pmax(E(g_w)$weight, .Machine$double.eps)

# Compute betweenness using weights as distances
btw_w <- betweenness(g_w, weights = E(g_w)$weight, normalized = TRUE)

btw_w %>% sort # now a different taxon is the most important!


#HEATMAP ~~~~~~~~~~~~~~~~~~~~~~

#install.packages(c("pheatmap"))
library(pheatmap)


pheatmap(otu_cor,
         clustering_method = "complete",
         color = colorRampPalette(c("blue","white","red"))(50),
         breaks = seq(-1, 1, length.out = 51),
         main = "Pearson's Correlation Heatmap")
        
